# === Google Sheets ===
# Copia el contenido del JSON de tu Service Account aquí
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# El ID de tu hoja de cálculo (está en la URL)
# https://docs.google.com/spreadsheets/d/tu_spreadsheet_id_aqui/
SPREADSHEET_ID=tu_spreadsheet_id_aqui

# Nombre de la hoja dentro del archivo (pestaña)
SHEET_NAME=Hoja1

# === Telegram (para fase 2) ===
TELEGRAM_BOT_TOKEN=tu_token_del_bot_aqui
ALLOWED_USER_IDS=tu_user_id_de_telegram

# === Exchange Rate ===
# Usa "dolarapi" o "bcv"
EXCHANGE_SOURCE=dolarapi
