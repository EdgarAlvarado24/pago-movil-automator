# === PostgreSQL ===
# URL de conexión a PostgreSQL (Supabase, Neon, Railway, etc.)
DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require

# === Telegram ===
TELEGRAM_BOT_TOKEN=tu_token_del_bot_aqui

# ID de Telegram del administrador (quien gestiona whitelist, etc.)
# Se obtiene enviando /start al bot @userinfobot
ADMIN_TELEGRAM_ID=tu_user_id_de_telegram

# === Exchange Rate ===
# Fuente: "dolarapi" (recomendado) o "bcv"
EXCHANGE_SOURCE=dolarapi
# Modo: "oficial" (BCV) o "paralelo" (mercado paralelo)
EXCHANGE_MODE=oficial

# === Encryption ===
# Clave maestra para encriptar Service Account JSONs en la DB
# Genera una con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=genera_una_clave_con_el_comando_de_arriba

# === Logging ===
# Nivel de log: error, warn, info, debug
LOG_LEVEL=info
