# === PostgreSQL ===
DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require

# === Telegram ===
TELEGRAM_BOT_TOKEN=tu_token_del_bot_aqui
ADMIN_TELEGRAM_ID=tu_user_id_de_telegram

# === OAuth2 de Google (reemplaza a Service Account) ===
# 1. Ve a https://console.cloud.google.com/apis/credentials
# 2. Crea un "OAuth 2.0 Client ID" de tipo "Aplicación web"
# 3. Agrega como URI de redirección autorizada: http://TU_IP:3456/oauth/callback
# 4. Copia el Client ID y Client Secret aquí:
GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=tu_client_secret

# URL donde corre el servidor OAuth (debe coincidir con la registrada en Google)
#
# ⚡ ¿Tu máquina NO está expuesta a internet?
# Usa http://127.0.0.1:3456/oauth/callback (Google permite loopback)
# El usuario autoriza desde su navegador y Google redirige a localhost.
# Si falla la conexión, el usuario pega la URL de la barra de direcciones.
#
# Opciones:
#   Loopback (recomendado, sin internet): http://127.0.0.1:3456/oauth/callback
#   Localhost:                             http://localhost:3456/oauth/callback
#   Red local:                             http://192.168.x.x:3456/oauth/callback
#   ngrok/tunnel:                          https://xxxx.ngrok.io/oauth/callback
OAUTH_REDIRECT_URI=http://127.0.0.1:3456/oauth/callback

# Puerto del servidor HTTP para callback OAuth
OAUTH_PORT=3456

# === Exchange Rate ===
EXCHANGE_SOURCE=dolarapi
EXCHANGE_MODE=oficial

# === Encryption ===
ENCRYPTION_KEY=genera_una_clave_con_npm_run_generate_key

# === Logging ===
LOG_LEVEL=info
